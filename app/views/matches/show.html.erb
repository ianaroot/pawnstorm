<div class="match-show-page">
  <%= render 'shared/condition_sentence_spec' %>
  <% if @match.awaiting_generation? %>
    <meta http-equiv="refresh" content="2">
  <% end %>

  <% if @match.awaiting_generation? %>
    <div class="match-replay-page match-replay-layout">
      <div class="game-page">
        <%= render 'matches/match_summary', match: @match, rematch_options: @rematch_options %>
        <% if @match.error_message.present? %>
          <p class="match-show-error"><strong>Error:</strong> <%= @match.error_message %></p>
        <% end %>
        <%= render 'shared/match_arena', match: @match %>
      </div>

      <div class="bot-trace-panel replay-stack replay-shell">
        <p>Match is generating.</p>
      </div>
    </div>
  <% elsif @match.failed? %>
    <div class="game-page">
      <%= render 'matches/match_summary', match: @match, rematch_options: @rematch_options %>
      <p class="match-show-meta-item"><strong>White:</strong> <%= @match.player_display_name_for(:white) %></p>
      <p class="match-show-meta-item"><strong>Black:</strong> <%= @match.player_display_name_for(:black) %></p>
      <p>Match generation failed.</p>
      <% if @match.error_message.present? %>
        <p class="match-show-error"><strong>Error:</strong> <%= @match.error_message %></p>
      <% end %>
    </div>
  <% else %>
    <div
      class="match-replay-page match-replay-layout"
      data-controller="tour"
      data-tour-set-value="matches-show"
      data-match-replay-page="true"
      data-final-layout="<%= json_escape(@match.lay_out.to_json) %>"
      data-movement-notation="<%= json_escape(@match.movement_notation.to_json) %>"
      data-result="<%= @match.result %>"
      data-current-user-id="<%= current_user.id %>"
      data-white-name="<%= @match.player_display_name_for(:white) %>"
      data-black-name="<%= @match.player_display_name_for(:black) %>"
      data-white-bot-owner-id="<%= @match.white_tournament_entry&.bot_owner_id || (@match.white_player_type == 'Bot' ? @match.white_player&.user_id : '') %>"
      data-black-bot-owner-id="<%= @match.black_tournament_entry&.bot_owner_id || (@match.black_player_type == 'Bot' ? @match.black_player&.user_id : '') %>"
      data-white-compiled-program-snapshot="<%= json_escape(@match.compiled_program_snapshot_for(:white).to_json) %>"
      data-black-compiled-program-snapshot="<%= json_escape(@match.compiled_program_snapshot_for(:black).to_json) %>"
    >
      <div class="game-page">
        <% if @match.error_message.present? %>
          <p class="match-show-error"><strong>Error:</strong> <%= @match.error_message %></p>
        <% end %>
        <div class="replay-controls replay-stack replay-shrink-0">
          <div class="replay-meta-row">
            <%= render 'matches/match_summary', match: @match, rematch_options: @rematch_options, show_tour_button: true %>
            <p data-match-replay-target="result"></p>
          </div>
          <div class="match-replay-controls replay-inline replay-inline--center">
            <button type="button" data-match-replay-target="start-button">Restart</button>
            <button type="button" data-match-replay-target="back-button">Back</button>
            <button type="button" data-match-replay-target="forward-button">Forward</button>
            <button type="button" data-match-replay-target="play-button">Play</button>
            <button type="button" data-match-replay-target="reverse-button">Reverse</button>
            <button type="button" data-match-replay-target="top-moves-toggle">Mute top moves</button>
          </div>
          <div class="match-replay-speed replay-inline replay-inline--center">
            <div class="match-replay-speed-buttons replay-inline">
              <button type="button" data-match-replay-target="speed-button" data-speed-multiplier="0.5">0.5x</button>
              <button type="button" data-match-replay-target="speed-button" data-speed-multiplier="1">1x</button>
              <button type="button" data-match-replay-target="speed-button" data-speed-multiplier="2">2x</button>
              <button type="button" data-match-replay-target="speed-button" data-speed-multiplier="4">4x</button>
              <button type="button" data-match-replay-target="speed-button" data-speed-multiplier="8">8x</button>
            </div>
          </div>
          <p data-match-replay-target="warning" hidden></p>
        </div>
        <%= render 'shared/match_arena', match: @match %>
      </div>

      <div class="match-replay-notation-column replay-scroll-y">
        <ol data-match-replay-target="notation" class="match-replay-notation"></ol>
      </div>

      <div class="bot-trace-panel replay-stack replay-shell">
        <div class="match-replay-trace replay-stack replay-shell replay-grow" data-match-replay-target="trace-panel" hidden>
          <div class="match-replay-trace-summary" data-match-replay-target="trace-summary"></div>
          <div class="match-replay-trace-branches replay-stack replay-scroll-y replay-grow" data-match-replay-target="trace-branches"></div>
        </div>
      </div>
    </div>
  <% end %>
</div>
