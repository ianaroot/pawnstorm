<div class="match-show-page">
  <% if @match.pending? || @match.running? %>
    <meta http-equiv="refresh" content="2">
  <% end %>

  <h1>Match <%= @match.id %></h1>

  <p>Status: <%= @match.status %></p>

  <% if @match.result.present? %>
    <p>Result: <%= @match.result %></p>
  <% end %>

  <% if @match.error_message.present? %>
    <p>Error: <%= @match.error_message %></p>
  <% end %>

  <% if @match.pending? || @match.running? %>
    <p>Match is generating.</p>
  <% elsif @match.failed? %>
    <p>Match generation failed.</p>
  <% else %>
    <p>Replay UI not built yet.</p>
  <% end %>
</div>
