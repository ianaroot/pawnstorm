<% owned = current_user.present? && bot.user_id == current_user.id %>
<label class="match-bot-option">
  <input type="radio"
    name="<%= radio_name %>"
    value="<%= bot.id %>"
    form="match-form"
    <%= 'checked' if checked %>
    <% if local_assigns[:change_action].present? %>data-action="<%= change_action %>"<% end %>
    data-bot-name="<%= bot.name %>"
    data-bot-stale="<%= bot.compiled_program_stale? %>"
    data-bot-owned="<%= owned %>">
  <span class="match-bot-option__name">
    <strong><%= bot.name %></strong>
  </span>
  <% if show_details %>
    <span class="match-bot-option__rating"><%= bot.rating.round %></span>
    <% if local_assigns.fetch(:show_owner, true) %>
      <span class="match-bot-option__owner"><%= bot.user.username %></span>
    <% end %>
  <% end %>
</label>
