<div class="match-setup-nav">
  <nav class="match-mode-toggle">
    <% if current_mode == :bot_vs_bot %>
      <span class="match-mode-toggle__option match-mode-toggle__option--active">Bot vs Bot</span>
    <% else %>
      <%= link_to 'Bot vs Bot', new_bot_vs_bot_match_path, class: 'match-mode-toggle__option' %>
    <% end %>
    <% if current_mode == :human_vs_bot %>
      <span class="match-mode-toggle__option match-mode-toggle__option--active">You vs Bot</span>
    <% else %>
      <%= link_to 'You vs Bot', new_human_vs_bot_match_path, class: 'match-mode-toggle__option' %>
    <% end %>
  </nav>
  <%= link_to 'Past matches', matches_path, class: 'btn btn-secondary' %>
</div>
