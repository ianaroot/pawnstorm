<div class="match-setup-page">
  <h1>Set Up Match</h1>
  <p>Choose one of your bots and an opponent. Colors will be assigned randomly. Your stale bots can still be selected, but they must be recompiled before a match can be generated.</p>

  <%= form_with url: matches_path, scope: :match, method: :post, local: true do |form| %>
    <div class="match-setup-section">
      <h2>Your Bot</h2>
      <div class="match-bot-list-frame">
        <div class="match-bot-list">
          <% @own_bots.each do |bot| %>
            <label class="match-bot-option">
              <%= form.radio_button :own_bot_id, bot.id, checked: @selected_own_bot_id.to_i == bot.id %>
              <span>
                <strong><%= bot.name %></strong>
                <small>by <%= bot.user.email %></small>
                <%= ' (needs recompile)' if bot.compiled_program_stale? %>
              </span>
            </label>
          <% end %>
        </div>
        <div class="match-bot-scroll-track" aria-hidden="true">
          <div class="match-bot-scroll-thumb"></div>
        </div>
      </div>
    </div>

    <div class="match-setup-section">
      <h2>Opponent Bot</h2>
      <div class="match-bot-list-frame">
        <div class="match-bot-list">
          <% @all_opponent_bots.each do |bot| %>
            <label class="match-bot-option">
              <%= form.radio_button :opponent_bot_id, bot.id, checked: @selected_opponent_bot_id.to_i == bot.id %>
              <span>
                <strong><%= bot.name %></strong>
                <small>by <%= bot.user.email %></small>
                <%= ' (needs recompile)' if bot.compiled_program_stale? %>
              </span>
            </label>
          <% end %>
        </div>
        <div class="match-bot-scroll-track" aria-hidden="true">
          <div class="match-bot-scroll-thumb"></div>
        </div>
      </div>
    </div>

    <%= form.submit 'Create Match' %>
  <% end %>
</div>
