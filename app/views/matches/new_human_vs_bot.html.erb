<%= render layout: 'matches/setup_page', locals: {
      title: 'Play Against Your Bot',
      mode: :human_vs_bot,
      form_url: human_vs_bot_matches_path,
      submit_label: 'Start Game'
    } do %>
    <div class="match-setup-col">
      <div class="setup-section" data-controller="sort">
        <h2>Opponent Bot</h2>
        <%= render layout: "shared/index_filter_form", locals: { url: new_human_vs_bot_match_path, frame: "play-bots-frame" } do |f| %>
          <%= f.hidden_field :bot_id, value: params[:bot_id] %>
          <%= f.hidden_field :human_color, value: params[:human_color] %>
          <%= f.hidden_field :sort, value: params[:sort], data: { sort_target: 'field' } %>
          <div class="index-filter-row">
            <%= f.text_field :bot_name, value: params[:bot_name], placeholder: 'Search by name', class: 'index-filter-input match-setup-filter-input', data: { action: 'input->auto-submit#submitDebounced' } %>
          </div>
        <% end %>
        <%= turbo_frame_tag "play-bots-frame" do %>
          <%= render 'matches/sort_controls', options: Matches::SortOptions.new(params[:sort], default: Bot::DEFAULT_SORT).options %>
          <%= render 'matches/bot_list',
            bots: @play_bots,
            pagy: @play_bots_pagy,
            radio_name: 'match[bot_id]',
            selected_id: @selected_bot_id,
            show_details: true,
            show_owner: false %>
        <% end %>
      </div>
    </div>

    <div class="match-setup-col">
      <div class="setup-section">
        <h2>Your Color</h2>
        <label class="match-bot-option">
          <input type="radio" name="match[human_color]" value="white" form="match-form" <%= 'checked' if @selected_color == 'white' %>>
          <span><strong>White</strong> <small>You move first.</small></span>
        </label>
        <label class="match-bot-option">
          <input type="radio" name="match[human_color]" value="black" form="match-form" <%= 'checked' if @selected_color == 'black' %>>
          <span><strong>Black</strong> <small>Your bot moves first.</small></span>
        </label>
        <label class="match-bot-option">
          <input type="radio" name="match[human_color]" value="random" form="match-form" <%= 'checked' if @selected_color == 'random' %>>
          <span><strong>Random</strong> <small>Let fate wear the funny hat.</small></span>
        </label>
      </div>
    </div>
<% end %>
