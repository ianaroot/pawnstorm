<%
  files = ('a'..'h').to_a
  pieces = {
    'c3' => { glyph: '♘', tone: 'white' },
    'e2' => { glyph: '♙', tone: 'white' },
    'g1' => { glyph: '♔', tone: 'white' },
    'd5' => { glyph: '♞', tone: 'black' },
    'c6' => { glyph: '♟', tone: 'black' }
  }
  tile_states = {
    'c3' => 'match-replay-square--selected-piece',
    'd5' => 'match-replay-square--chosen-move',
    'b5' => 'match-replay-square--tied-move',
    'e4' => 'match-replay-square--selected-move'
  }
%>

<table class="bot-guide-replay__board-table" aria-hidden="true">
  <% 8.downto(1) do |rank| %>
    <tr>
      <% files.each_with_index do |file, index| %>
        <% square = "#{file}#{rank}" %>
        <% tile_color = (rank + index).even? ? 'white-tile' : 'black-tile' %>
        <% state_class = tile_states[square] %>
        <td class="chess-tile <%= tile_color %> <%= state_class %>">
          <% if pieces[square].present? %>
            <span class="bot-guide-replay__piece bot-guide-replay__piece--<%= pieces[square][:tone] %>"><%= pieces[square][:glyph] %></span>
          <% end %>
        </td>
      <% end %>
    </tr>
  <% end %>
</table>
