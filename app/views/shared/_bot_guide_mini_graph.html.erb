<svg class="bot-guide-mini-graph__svg" viewBox="0 0 640 430" aria-label="Branch ordering diagram">
  <defs>
    <marker id="bot-guide-mini-graph-arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
      <path d="M0,0 L8,4 L0,8 z" class="bot-guide-mini-graph__arrow-head"></path>
    </marker>
  </defs>

  <path
    class="bot-guide-mini-graph__orbit-path"
    d="M287 40 A66 66 0 1 0 377 64"
    marker-end="url(#bot-guide-mini-graph-arrow)"></path>
  <text x="320" y="18" class="bot-guide-mini-graph__orbit-text">counter-clockwise around the root output</text>

  <line class="bot-guide-mini-graph__connector" x1="320" y1="124" x2="320" y2="176"></line>
  <line class="bot-guide-mini-graph__connector" x1="320" y1="124" x2="156" y2="198"></line>
  <line class="bot-guide-mini-graph__connector" x1="320" y1="124" x2="484" y2="198"></line>
  <line class="bot-guide-mini-graph__connector" x1="320" y1="232" x2="320" y2="320"></line>

  <rect x="264" y="70" width="112" height="54" rx="10" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--root"></rect>
  <text x="320" y="102" class="bot-guide-mini-graph__label">Root</text>

  <rect x="260" y="176" width="120" height="56" rx="28" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--condition"></rect>
  <text x="320" y="203" class="bot-guide-mini-graph__label">Center child</text>
  <text x="320" y="219" class="bot-guide-mini-graph__order">2nd</text>

  <rect x="96" y="170" width="120" height="56" rx="28" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--condition"></rect>
  <text x="156" y="197" class="bot-guide-mini-graph__label">Left child</text>
  <text x="156" y="213" class="bot-guide-mini-graph__order">1st</text>

  <rect x="424" y="170" width="120" height="56" rx="28" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--condition"></rect>
  <text x="484" y="197" class="bot-guide-mini-graph__label">Right child</text>
  <text x="484" y="213" class="bot-guide-mini-graph__order">4th</text>

  <rect x="264" y="320" width="112" height="52" rx="8" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--score"></rect>
  <text x="320" y="350" class="bot-guide-mini-graph__label">Deep child</text>
  <text x="320" y="365" class="bot-guide-mini-graph__order">3rd</text>

  <text x="320" y="402" class="bot-guide-mini-graph__note">Depth-first means Pawnstorm follows the first branch downward</text>
  <text x="320" y="416" class="bot-guide-mini-graph__note">before returning to the right-side sibling.</text>
</svg>
