<section
  class="sidebar__tips"
  data-controller="tips-rail"
  data-action="mouseenter->tips-rail#pause mouseleave->tips-rail#resume">
  <p class="sidebar__tips-label"><%= label %></p>

  <div class="tips-rail">
    <% tips.each_with_index do |tip, index| %>
      <article
        class="tips-rail__card tips-rail__card--<%= tip.fetch(:accent) %> <%= 'is-active' if index.zero? %>"
        data-tips-rail-target="card"
        data-index="<%= index %>"
        <% unless index.zero? %>hidden<% end %>>
        <div class="tips-rail__media">
          <%= render 'shared/tips_rail_image', image: tip[:image] %>
        </div>

        <div class="tips-rail__content">
          <p class="tips-rail__eyebrow"><%= tip.fetch(:eyebrow) %></p>
          <h3 class="tips-rail__title"><%= tip.fetch(:title) %></h3>
          <p class="tips-rail__body"><%= tip.fetch(:body) %></p>
        </div>
      </article>
    <% end %>
  </div>

  <% if tips.length > 1 %>
    <div class="tips-rail__dots" aria-label="Tip navigation">
      <% tips.each_with_index do |_tip, index| %>
        <button
          type="button"
          class="tips-rail__dot <%= 'is-active' if index.zero? %>"
          data-tips-rail-target="dot"
          data-action="click->tips-rail#goTo"
          data-index="<%= index %>"
          aria-label="Show tip <%= index + 1 %>"
          aria-pressed="<%= index.zero? %>"></button>
      <% end %>
    </div>
  <% end %>
</section>
