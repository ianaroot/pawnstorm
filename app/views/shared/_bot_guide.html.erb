<% mode_class = mode.to_s == 'drawer' ? 'bot-guide--drawer' : 'bot-guide--full' %>

<div class="bot-guide <%= mode_class %>">
  <% sections.each do |section| %>
    <section id="<%= section[:id] %>" class="bot-guide-section">
      <h2 class="bot-guide-section__title"><%= section[:title] %></h2>
      <p class="bot-guide-section__intro">
        <%= format_bot_guide_text(section[:intro]) %>
      </p>

      <% if section[:visual].present? %>
        <div class="bot-guide-visual bot-guide-visual--<%= section[:visual][:kind] %>">
          <h3 class="bot-guide-visual__title"><%= section[:visual][:title] %></h3>
          <p class="bot-guide-visual__caption"><%= section[:visual][:caption] %></p>

          <% case section[:visual][:kind] %>
          <% when 'node_pair' %>
            <div class="bot-guide-node-pair">
              <% Array(section[:visual][:cards]).each do |card| %>
                <article class="bot-guide-node-card bot-guide-node-card--<%= card[:type] %>">
                  <p class="bot-guide-node-card__eyebrow"><%= card[:title] %></p>
                  <div class="bot-guide-node-card__body">
                    <div class="bot-guide-node-card__preview"><%= card[:preview] %></div>
                  </div>
                  <p class="bot-guide-node-card__note"><%= card[:note] %></p>
                </article>
              <% end %>
            </div>
          <% when 'mini_graph' %>
            <div class="bot-guide-mini-graph">
              <svg class="bot-guide-mini-graph__svg" viewBox="0 0 640 430" aria-label="Branch ordering diagram">
                <defs>
                  <marker id="bot-guide-mini-graph-arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
                    <path d="M0,0 L8,4 L0,8 z" class="bot-guide-mini-graph__arrow-head"></path>
                  </marker>
                </defs>

                <path
                  class="bot-guide-mini-graph__orbit-path"
                  d="M287 40 A66 66 0 1 0 377 64"
                  marker-end="url(#bot-guide-mini-graph-arrow)"></path>
                <text x="320" y="18" class="bot-guide-mini-graph__orbit-text">counter-clockwise around the root output</text>

                <line class="bot-guide-mini-graph__connector" x1="320" y1="124" x2="320" y2="176"></line>
                <line class="bot-guide-mini-graph__connector" x1="320" y1="124" x2="156" y2="198"></line>
                <line class="bot-guide-mini-graph__connector" x1="320" y1="124" x2="484" y2="198"></line>
                <line class="bot-guide-mini-graph__connector" x1="320" y1="232" x2="320" y2="320"></line>

                <rect x="264" y="70" width="112" height="54" rx="10" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--root"></rect>
                <text x="320" y="102" class="bot-guide-mini-graph__label">Root</text>

                <rect x="260" y="176" width="120" height="56" rx="28" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--condition"></rect>
                <text x="320" y="203" class="bot-guide-mini-graph__label">First child</text>
                <text x="320" y="219" class="bot-guide-mini-graph__order">2nd</text>

                <rect x="96" y="170" width="120" height="56" rx="28" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--condition"></rect>
                <text x="156" y="197" class="bot-guide-mini-graph__label">Second child</text>
                <text x="156" y="213" class="bot-guide-mini-graph__order">1st</text>

                <rect x="424" y="170" width="120" height="56" rx="28" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--condition"></rect>
                <text x="484" y="197" class="bot-guide-mini-graph__label">Third child</text>
                <text x="484" y="213" class="bot-guide-mini-graph__order">4th</text>

                <rect x="264" y="320" width="112" height="52" rx="8" class="bot-guide-mini-graph__shape bot-guide-mini-graph__shape--action"></rect>
                <text x="320" y="350" class="bot-guide-mini-graph__label">Deep child</text>
                <text x="320" y="365" class="bot-guide-mini-graph__order">3rd</text>

                <text x="320" y="402" class="bot-guide-mini-graph__note">Depth-first means Pawnstorm follows the first branch downward</text>
                <text x="320" y="416" class="bot-guide-mini-graph__note">before returning to the right-side sibling.</text>
              </svg>
            </div>
          <% when 'replay_panel' %>
            <div class="bot-guide-replay">
              <div class="bot-guide-replay__mock">
                <div class="bot-guide-replay__board">
                  <%= render 'shared/bot_guide_replay_board' %>
                </div>
                <div class="bot-guide-replay__trace">
                  <p class="bot-guide-replay__trace-title">Trace for inspected move</p>
                  <div class="bot-guide-replay__trace-row">Condition: captured piece value &gt;= moved piece</div>
                  <div class="bot-guide-replay__trace-row">Action: return 100</div>
                </div>
              </div>

              <div class="bot-guide-replay__legend">
                <% Array(section[:visual][:legend]).each do |item| %>
                  <div class="bot-guide-replay__legend-item">
                    <span class="bot-guide-replay__legend-swatch bot-guide-replay__legend-swatch--<%= item[:tone] %>"></span>
                    <span><%= item[:label] %></span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if section[:bullets].present? %>
        <ul class="bot-guide-list">
          <% section[:bullets].each do |bullet| %>
            <li><%= bullet %></li>
          <% end %>
        </ul>
      <% end %>

      <% Array(section[:examples]).each do |example| %>
        <article class="bot-guide-example">
          <h3 class="bot-guide-example__title"><%= example[:title] %></h3>
          <p class="bot-guide-example__explanation"><%= format_bot_guide_text(example[:explanation]) %></p>

          <div class="bot-guide-snippets">
            <% Array(example[:snippets]).each do |snippet| %>
              <div class="bot-guide-snippet">
                <p class="bot-guide-snippet__label"><%= snippet[:label] %></p>
                <% if bot_guide_structured_snippet?(snippet[:body]) %>
                  <div class="bot-guide-snippet__rows">
                    <% bot_guide_snippet_rows(snippet[:body]).each do |row| %>
                      <div class="bot-guide-snippet__row">
                        <span class="bot-guide-snippet__key"><%= row[:key] %></span>
                        <span class="bot-guide-snippet__value"><%= row[:value] %></span>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <pre><code><%= snippet[:body] %></code></pre>
                <% end %>
              </div>
            <% end %>
          </div>
        </article>
      <% end %>
    </section>
  <% end %>
</div>
