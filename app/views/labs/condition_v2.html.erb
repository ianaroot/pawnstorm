<h1>Condition V2 Lab</h1>

<div class="bot-editor condition-lab-shell" data-controller="condition-lab">
  <div class="editor-toolbar">
    <div class="toolbar-section">
      <h3>Lab</h3>
      <p class="lab-toolbar-copy">Local-only grammar sandbox. No DB, no compile path.</p>
    </div>

    <div class="toolbar-section">
      <%= link_to 'Back to Bots', bots_path, class: 'btn-back' %>
    </div>
  </div>

  <div class="editor-main">
    <div class="canvas-container">
      <div id="canvas-workspace" class="canvas-workspace">
        <div id="canvas-scene" class="canvas-scene">
          <div id="nodes-canvas" class="nodes-layer">
            <div
              class="node condition selected"
              style="left: 280px; top: 160px;"
              data-condition-lab-target="fakeNode"
              data-action="click->condition-lab#handleNodeClick">
              <div class="node-content">
                <div class="node-preview condition-preview" data-condition-lab-target="nodePreview"></div>
              </div>
              <div class="node-connector input"></div>
              <div class="node-connector output"></div>
            </div>
          </div>
          <svg id="connections-canvas" class="connections-layer"></svg>
        </div>
      </div>
    </div>
  </div>

  <div id="node-editor-panel" class="node-editor-panel condition-lab-panel" data-condition-lab-target="editorPanel">
    <h3>Edit Node</h3>

    <div class="panel-content condition-lab-panel__content">
      <div class="form-group">
        <label>Type</label>
        <span>condition_v2_mock</span>
      </div>

      <div class="condition-lab-layout">
        <section class="condition-lab-side">
          <div class="condition-lab-side__header">
            <span class="condition-lab-side__label">Subject</span>
          </div>

          <div class="condition-lab-field">
            <label>Subject</label>
            <select data-condition-lab-target="leftSubject" data-path="left.subject" data-action="change->condition-lab#updateField"></select>
          </div>

          <div class="condition-lab-field">
            <div class="condition-lab-inline-pair">
              <label class="condition-lab-checkbox">
                <input data-condition-lab-target="leftSpecifierMode" data-path="left.specifierMode" data-action="change->condition-lab#updateField" type="checkbox">
                <span>Non-</span>
              </label>
              <select data-condition-lab-target="leftSpecifier" data-path="left.specifier" data-action="change->condition-lab#updateField"></select>
            </div>
          </div>

          <div class="condition-lab-comparison" data-condition-lab-target="leftComparisonSection">
            <button
              type="button"
              class="condition-lab-comparison__toggle"
              data-condition-lab-target="leftComparisonToggle"
              data-side="left"
              data-action="click->condition-lab#toggleComparison">
            </button>

            <div class="condition-lab-comparison__body hidden" data-condition-lab-target="leftComparisonBody">
              <div class="condition-lab-field" data-condition-lab-target="leftComparisonField">
                <label>Comparison</label>
                <div class="condition-lab-comparison-grid condition-lab-comparison-grid--relation" data-condition-lab-target="leftComparisonRow">
                  <select data-condition-lab-target="leftMetric" data-path="left.comparisonMetric" data-action="change->condition-lab#updateField"></select>
                  <select data-condition-lab-target="leftComparison" data-path="left.comparison" data-action="change->condition-lab#updateField"></select>
                  <div class="condition-lab-comparison-value-stack">
                    <select data-condition-lab-target="leftComparisonValueSource" data-path="left.comparisonValueSource" data-action="change->condition-lab#updateField"></select>
                    <input data-condition-lab-target="leftComparisonValueNumber" data-path="left.comparisonValueNumber" data-action="input->condition-lab#updateField" type="number" min="0" step="1">
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="condition-lab-verb">
          <label>Verb</label>
          <select data-condition-lab-target="verbSelector" data-action="change->condition-lab#changeVerbFamily"></select>
        </section>

        <section class="condition-lab-side" data-condition-lab-target="rightCard">
          <div class="condition-lab-side__header">
            <span class="condition-lab-side__label" data-condition-lab-target="rightCardLabel">Target</span>
          </div>

          <div data-condition-lab-target="rightRelationFields">
            <div class="condition-lab-field">
              <label>Subject</label>
              <select data-condition-lab-target="rightSubject" data-path="right.subject" data-action="change->condition-lab#updateField"></select>
            </div>

            <div class="condition-lab-field">
              <div class="condition-lab-inline-pair">
                <label class="condition-lab-checkbox">
                  <input data-condition-lab-target="rightSpecifierMode" data-path="right.specifierMode" data-action="change->condition-lab#updateField" type="checkbox">
                  <span>Non-</span>
                </label>
                <select data-condition-lab-target="rightSpecifier" data-path="right.specifier" data-action="change->condition-lab#updateField"></select>
              </div>
            </div>

            <div class="condition-lab-comparison">
              <button
                type="button"
                class="condition-lab-comparison__toggle"
                data-condition-lab-target="rightComparisonToggle"
                data-side="right"
                data-action="click->condition-lab#toggleComparison">
              </button>

              <div class="condition-lab-comparison__body hidden" data-condition-lab-target="rightComparisonBody">
                <div class="condition-lab-field" data-condition-lab-target="rightComparisonField">
                  <label>Comparison</label>
                  <div class="condition-lab-comparison-grid condition-lab-comparison-grid--relation" data-condition-lab-target="rightComparisonRow">
                    <select data-condition-lab-target="rightMetric" data-path="right.comparisonMetric" data-action="change->condition-lab#updateField"></select>
                    <select data-condition-lab-target="rightComparison" data-path="right.comparison" data-action="change->condition-lab#updateField"></select>
                    <div class="condition-lab-comparison-value-stack">
                      <select data-condition-lab-target="rightComparisonValueSource" data-path="right.comparisonValueSource" data-action="change->condition-lab#updateField"></select>
                      <input data-condition-lab-target="rightComparisonValueNumber" data-path="right.comparisonValueNumber" data-action="input->condition-lab#updateField" type="number" min="0" step="1">
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="condition-lab-comparison hidden" data-condition-lab-target="unaryComparisonSection">
            <div class="condition-lab-field">
              <label>Comparison</label>
              <div class="condition-lab-comparison-grid condition-lab-comparison-grid--unary" data-condition-lab-target="unaryComparisonRow">
                <select data-condition-lab-target="unaryComparison" data-path="unary.comparison" data-action="change->condition-lab#updateField"></select>
                <div class="condition-lab-comparison-value-stack">
                  <select data-condition-lab-target="unaryComparisonValueSource" data-path="unary.comparisonValueSource" data-action="change->condition-lab#updateField"></select>
                  <input data-condition-lab-target="unaryComparisonValueNumber" data-path="unary.comparisonValueNumber" data-action="input->condition-lab#updateField" type="number" min="0" step="1">
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <div class="condition-lab-note" data-condition-lab-target="priorNote"></div>

      <div class="condition-lab-formulation">
        <label>Current Condition</label>
        <div class="condition-lab-formulation__text" data-condition-lab-target="formulationPreview"></div>
      </div>
    </div>
  </div>
</div>
