<!DOCTYPE html>
<html>
  <head>
    <title>Pawnstorm</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%# Always include CSRF token for JavaScript API calls even when forgery protection is disabled %>
    <% if protect_against_forgery? == false && respond_to?(:form_authenticity_token) %>
      <meta name="csrf-param" content="authenticity_token">
      <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <% end %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-environment="<%= Rails.env %>">
    <%= render "shared/sidebar" %>
    
    <main class="content-wrapper">
      <div class="page-content <%= yield(:page_content_class) %>">
        <% if notice.present? || alert.present? %>
          <div class="flash-toasts" data-controller="flash" data-turbo-cache="false">
            <% if notice.present? %>
              <div class="flash-toast notice" role="status" data-flash-target="toast" data-dismiss-after="5000">
                <span class="flash-toast__message"><%= notice %></span>
                <button type="button" class="flash-toast__close" data-action="flash#dismiss" aria-label="Dismiss">&times;</button>
              </div>
            <% end %>

            <% if alert.present? %>
              <div class="flash-toast alert" role="alert" data-flash-target="toast">
                <span class="flash-toast__message"><%= alert %></span>
                <button type="button" class="flash-toast__close" data-action="flash#dismiss" aria-label="Dismiss">&times;</button>
              </div>
            <% end %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
