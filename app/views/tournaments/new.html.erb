<div class="setup-form-page">
  <h1>New Tournament</h1>
  <p>Create the shell first — users can submit entries while registration is open.</p>

  <%= form_with url: tournaments_path, scope: :tournament, method: :post, local: true do |form| %>
    <div class="setup-form-grid">
      <div class="setup-form-col">
        <div class="setup-form-section">
          <h2>Details</h2>
          <div class="form-field">
            <%= form.label :name, 'Name' %>
            <%= form.text_field :name, value: @name %>
          </div>
          <div class="form-field">
            <%= form.label :description, 'Description' %>
            <%= form.text_area :description, value: @description, rows: 6 %>
          </div>
        </div>

        <div class="setup-form-section">
          <h2>Format</h2>
          <p>Default is 10 games per pairing. Maximum is <%= Tournaments::CreateTournament::MAX_GAMES_PER_PAIR %>.</p>
          <div class="form-field form-field-narrow">
            <%= form.label :games_per_pair, 'Games Per Pairing' %>
            <%= form.number_field :games_per_pair, value: @games_per_pair, min: 1, max: Tournaments::CreateTournament::MAX_GAMES_PER_PAIR, step: 1 %>
          </div>
        </div>

        <%= form.submit 'Create Tournament', class: 'btn btn-primary' %>
      </div>

      <div class="setup-form-col">
        <div class="setup-form-section">
          <h2>Access</h2>
          <p>Public tournaments are listed. Link-only tournaments are accessible by invite link.</p>
          <div class="form-field form-field-narrow">
            <%= form.label :visibility, 'Visibility' %>
            <%= form.select :visibility,
              Tournament.visibilities.keys.map { |v| [v.humanize, v] },
              selected: @visibility %>
          </div>
        </div>

        <div class="setup-form-section">
          <h2>Entries</h2>
          <p>One-entry mode lets each user replace their entry before start. Unlimited allows multiple entries per user, one per bot.</p>
          <div class="form-field form-field-narrow">
            <%= form.label :entries_per_user, 'Entries Per User' %>
            <%= form.select :entries_per_user,
              Tournament.entries_per_users.keys.map { |e| [e.humanize, e] },
              selected: @entries_per_user %>
          </div>
          <div class="form-field form-field-narrow">
            <%= form.label :max_entries, 'Max Entries' %>
            <%= form.number_field :max_entries, value: @max_entries, min: 2, step: 1, placeholder: 'Unlimited' %>
          </div>
        </div>
      </div>
    </div>

    <details class="constraints-section" <%= "open" if @constraints.present? %>>
      <summary class="constraints-summary">Bot Eligibility Constraints</summary>
      <div class="constraints-body">
        <p class="constraints-intro">Leave all fields blank to allow any bot. Set restrictions to limit which bots can enter this tournament.</p>

        <div class="constraints-grid">
          <div class="constraints-col">
            <h3 class="constraints-col-heading">Budget</h3>
            <div class="form-field form-field-narrow">
              <label for="constraints_budget">Total Budget</label>
              <input type="number" id="constraints_budget"
                name="tournament[constraints][budget]"
                value="<%= @constraints&.dig("budget") %>"
                min="0" step="1" placeholder="None"
                onblur="if(this.value==='0')this.value=''">
            </div>

            <p class="constraints-hint">Cost per component (leave blank to exclude from budget):</p>
            <% cost_labels = {
              "score_node"           => "Score node",
              "unary_condition"      => "Unary condition",
              "relational_condition" => "Relational condition",
              "position_condition"   => "Position condition",
              "and"                  => "AND edge",
              "or"                   => "OR merge"
            } %>
            <div class="cost-fields-grid">
              <% cost_labels.each do |key, label| %>
                <div class="form-field form-field-narrow">
                  <label for="constraints_costs_<%= key %>"><%= label %></label>
                  <input type="number" id="constraints_costs_<%= key %>"
                    name="tournament[constraints][costs][<%= key %>]"
                    value="<%= @constraints&.dig("costs", key) %>"
                    min="0" step="1" placeholder="Free"
                    onblur="if(this.value==='0')this.value=''">
                </div>
              <% end %>
            </div>
          </div>

          <div class="constraints-col constraints-col--centered">
            <h3 class="constraints-col-heading">Structure</h3>

            <div class="check-field">
              <label class="check-label">
                <input type="checkbox"
                  name="tournament[constraints][allow_and]"
                  value="false"
                  <%= "checked" if @constraints&.dig("allow_and") == false %>>
                Disallow AND branches
              </label>
            </div>
            <div class="check-field">
              <label class="check-label">
                <input type="checkbox"
                  name="tournament[constraints][allow_or]"
                  value="false"
                  <%= "checked" if @constraints&.dig("allow_or") == false %>>
                Disallow OR branches
              </label>
            </div>

            <div class="form-field form-field-narrow" style="margin-top: 0.75rem;">
              <label for="constraints_max_branch_length">Max Branch Length</label>
              <input type="number" id="constraints_max_branch_length"
                name="tournament[constraints][max_branch_length]"
                value="<%= @constraints&.dig("max_branch_length") %>"
                min="1" step="1" placeholder="Unlimited">
            </div>
          </div>

          <div class="constraints-banned">
            <div class="constraints-col">
              <h3 class="constraints-col-heading">Banned Condition Kinds</h3>
              <p class="constraints-hint">Check to ban that condition kind.</p>
              <% %w[unary relational position].each do |kind| %>
                <label class="check-label">
                  <input type="checkbox"
                    name="tournament[constraints][condition_restrictions][banned_kinds][]"
                    value="<%= kind %>"
                    <%= "checked" if @constraints&.dig("condition_restrictions", "banned_kinds")&.include?(kind) %>>
                  <%= kind %>
                </label>
              <% end %>
            </div>

            <div class="constraints-col">
              <h3 class="constraints-col-heading">Banned Score Actions</h3>
              <p class="constraints-hint">Check to ban that action type.</p>
              <% %w[add subtract set return].each do |action_type| %>
                <label class="check-label">
                  <input type="checkbox"
                    name="tournament[constraints][score_node_restrictions][banned_action_types][]"
                    value="<%= action_type %>"
                    <%= "checked" if @constraints&.dig("score_node_restrictions", "banned_action_types")&.include?(action_type) %>>
                  <%= action_type %>
                </label>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </details>

  <% end %>
</div>
