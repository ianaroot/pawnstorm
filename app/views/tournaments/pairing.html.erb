<div class="match-show-page">
  <div class="match-replay-layout tournament-show-layout">
    <div class="game-page tournament-page">
      <div class="match-show-meta">
        <h1 class="match-show-title"><%= @pairing[:bot_a].name %> vs <%= @pairing[:bot_b].name %></h1>
        <p class="match-show-meta-item">
          <%= link_to "Back to Tournament #{@tournament.id}", tournament_path(@tournament) %>
        </p>
      </div>

      <div class="match-setup-section">
        <h2>Pairing Summary</h2>
        <table>
          <thead>
            <tr>
              <th><%= @pairing[:bot_a].name %> as White</th>
              <th><%= @pairing[:bot_b].name %> as White</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <%= @pairing[:bot_a].name %> <%= @pairing[:bot_a_white_record][:record][:bot_a_points] %> -
                <%= @pairing[:bot_a_white_record][:record][:bot_b_points] %> <%= @pairing[:bot_b].name %>
                (<%= @pairing[:bot_a_white_record][:record][:bot_a_wins] %>-<%= @pairing[:bot_a_white_record][:record][:bot_b_wins] %>, draws: <%= @pairing[:bot_a_white_record][:record][:draws] %>, failed: <%= @pairing[:bot_a_white_record][:record][:failed] %>)
              </td>
              <td>
                <%= @pairing[:bot_b].name %> <%= @pairing[:bot_b_white_record][:record][:bot_a_points] %> -
                <%= @pairing[:bot_b_white_record][:record][:bot_b_points] %> <%= @pairing[:bot_a].name %>
                (<%= @pairing[:bot_b_white_record][:record][:bot_a_wins] %>-<%= @pairing[:bot_b_white_record][:record][:bot_b_wins] %>, draws: <%= @pairing[:bot_b_white_record][:record][:draws] %>, failed: <%= @pairing[:bot_b_white_record][:record][:failed] %>)
              </td>
              <td>
                <%= @pairing[:bot_a].name %> <%= @pairing[:total_record][:bot_a_points] %> -
                <%= @pairing[:total_record][:bot_b_points] %> <%= @pairing[:bot_b].name %>
                (<%= @pairing[:total_record][:bot_a_wins] %>-<%= @pairing[:total_record][:bot_b_wins] %>, draws: <%= @pairing[:total_record][:draws] %>, failed: <%= @pairing[:total_record][:failed] %>)
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="match-setup-section">
        <h2>Matches</h2>
        <table>
          <thead>
            <tr>
              <th>Match</th>
              <th>White</th>
              <th>Black</th>
              <th>Status</th>
              <th>Result</th>
            </tr>
          </thead>
          <tbody>
            <% @pairing[:matches].each do |match| %>
              <tr>
                <td><%= link_to "Match #{match.id}", match_path(match) %></td>
                <td><%= match.white_player.respond_to?(:name) ? match.white_player.name : "#{match.white_player_type} #{match.white_player_id}" %></td>
                <td><%= match.black_player.respond_to?(:name) ? match.black_player.name : "#{match.black_player_type} #{match.black_player_id}" %></td>
                <td><%= match.status %></td>
                <td><%= match.result.presence || '-' %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
