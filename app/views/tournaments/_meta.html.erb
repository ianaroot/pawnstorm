<div class="match-show-meta">
  <h1 class="match-show-title"><%= tournament.name %></h1>
  <% if tournament.description.present? %>
    <p class="match-show-meta-item"><%= tournament.description %></p>
  <% end %>
  <p class="match-show-meta-item"><strong>Status:</strong> <%= tournament.status.humanize %></p>
  <p class="match-show-meta-item"><strong>Visibility:</strong> <%= tournament.visibility.humanize %></p>
  <p class="match-show-meta-item"><strong>Entries Per User:</strong> <%= tournament.entries_per_user.humanize %></p>
  <% if tournament.max_entries.present? %>
    <p class="match-show-meta-item"><strong>Max Entries:</strong> <%= tournament.max_entries %></p>
  <% end %>
  <p class="match-show-meta-item"><strong>Games Per Pair:</strong> <%= tournament.games_per_pair %></p>
  <% if current_user == tournament.creator || tournament.visibility_link_only? %>
    <p class="match-show-meta-item"><strong>Invite Link:</strong> <%= link_to invitation_tournament_path(tournament.invite_token), invitation_tournament_path(tournament.invite_token) %></p>
  <% end %>
  <% if tournament.status_open? && current_user == tournament.creator %>
    <p class="match-show-meta-item">
      <%= button_to 'Start Tournament', start_tournament_path(tournament), method: :post %>
    </p>
  <% end %>
  <% if tournament_presenter.entrants.any? %>
    <p class="match-show-meta-item"><strong>Entrants:</strong> <%= tournament_presenter.entrants.map(&:display_name).join(', ') %></p>
  <% end %>
  <% if tournament_presenter.active? && current_user == tournament.creator %>
    <p class="match-show-meta-item">
      <% if tournament.paused? %>
        <%= button_to 'Resume Tournament', resume_tournament_path(tournament), method: :post %>
      <% else %>
        <%= button_to 'Pause Tournament', pause_tournament_path(tournament), method: :post, data: { turbo_confirm: 'Pause this tournament? The current running match may finish, but no new matches will be queued.' } %>
      <% end %>
    </p>
    <p class="match-show-meta-item">
      <%= button_to 'Abort Tournament', abort_tournament_path(tournament), method: :post, data: { turbo_confirm: 'Abort this tournament? Pending matches will be marked failed.' } %>
    </p>
  <% end %>
</div>
