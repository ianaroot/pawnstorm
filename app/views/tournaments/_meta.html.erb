<div class="match-show-meta">
  <h1 class="match-show-title"><%= tournament.name %></h1>
  <% if tournament.description.present? %>
    <p class="match-show-meta-item"><%= tournament.description %></p>
  <% end %>

  <div class="tournament-details">
    <p class="tournament-details__heading">Details</p>
    <dl class="tournament-details__grid">
      <div class="tournament-details__row"><dt>Status</dt><dd><%= tournament.status.humanize %></dd></div>
      <div class="tournament-details__row"><dt>Visibility</dt><dd><%= tournament.visibility.humanize %></dd></div>
      <div class="tournament-details__row"><dt>Entries per user</dt><dd><%= tournament.entries_per_user.humanize %></dd></div>
      <% if tournament.max_entries.present? %>
        <div class="tournament-details__row"><dt>Max entries</dt><dd><%= tournament.max_entries %></dd></div>
      <% end %>
      <div class="tournament-details__row"><dt>Games per pair</dt><dd><%= tournament.games_per_pair %></dd></div>
    </dl>
  </div>

  <% if current_user == tournament.creator || tournament.visibility_link_only? %>
    <% invite_url = invitation_tournament_url(tournament.invite_token) %>
    <p class="match-show-meta-item invite-link" data-controller="clipboard" data-clipboard-text-value="<%= invite_url %>">
      <strong>Invite Link:</strong>
      <code class="invite-link__url"><%= invite_url %></code>
      <button type="button" class="invite-link__copy" data-clipboard-target="button" data-action="clipboard#copy">Copy</button>
    </p>
  <% end %>

  <% if tournament.status_open? && current_user == tournament.creator %>
    <p class="match-show-meta-item">
      <%= button_to 'Start Tournament', start_tournament_path(tournament), method: :post, class: 'btn btn-primary' %>
    </p>
  <% end %>

  <% if tournament_presenter.entrants.any? %>
    <p class="match-show-meta-item"><strong>Entrants:</strong> <%= tournament_presenter.entrants.map(&:display_name).join(', ') %></p>
  <% end %>

  <% if tournament_presenter.active? && current_user == tournament.creator %>
    <p class="match-show-meta-item">
      <% if tournament.paused? %>
        <%= button_to 'Resume Tournament', resume_tournament_path(tournament), method: :post, class: 'btn btn-secondary' %>
      <% else %>
        <%= button_to 'Pause Tournament', pause_tournament_path(tournament), method: :post, class: 'btn btn-secondary', data: { turbo_confirm: 'Pause this tournament? The current running match may finish, but no new matches will be queued.' } %>
      <% end %>
    </p>
    <% if Rails.env.local? %>
      <p class="match-show-meta-item">
        <%= button_to 'Abort Tournament', abort_tournament_path(tournament), method: :post, class: 'btn btn-danger', data: { turbo_confirm: 'Abort this tournament? Pending matches will be marked failed.' } %>
      </p>
    <% end %>
  <% end %>
</div>
