<div class="match-setup-section">
  <h2>Progress</h2>
  <p><strong>Total Matches:</strong> <span data-tournament-field="progress-total"><%= tournament.total_matches_count %></span></p>
  <p><strong>Pending:</strong> <span data-tournament-field="progress-pending"><%= tournament.pending_matches_count %></span></p>
  <p><strong>Running:</strong> <span data-tournament-field="progress-running"><%= tournament.running_matches_count %></span></p>
  <p><strong>Completed:</strong> <span data-tournament-field="progress-completed"><%= tournament.completed_matches_count %></span></p>
  <p><strong>Failed:</strong> <span data-tournament-field="progress-failed"><%= tournament.failed_matches_count %></span></p>
</div>
