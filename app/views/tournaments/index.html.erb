<div class="index-header">
  <h1>Tournaments</h1>
  <% if user_signed_in? && !current_user.guest? %>
    <%= link_to 'Create Tournament', new_tournament_path, class: 'btn btn-primary' %>
  <% end %>
</div>

<div class="index-panel">
<%= render layout: "shared/index_filter_form", locals: { url: tournaments_path, frame: "tournaments" } do |f| %>
  <div class="index-filter-row">
    <div class="index-filter-field">
      <%= f.text_field :name, value: params[:name], placeholder: 'Search by name', class: 'index-filter-input',
            data: { action: 'input->auto-submit#submitDebounced' } %>
    </div>
    <div class="index-filter-field">
      <%= f.text_field :owner, value: params[:owner], placeholder: 'Search by owner', class: 'index-filter-input',
            data: { action: 'input->auto-submit#submitDebounced' } %>
    </div>
    <div class="index-filter-field">
      <%= f.select :status,
        options_for_select(
          [['Any status', '']] + Tournament.statuses.keys.map { |s|
            [s.humanize, s, { class: "status-option status-option--#{pill_tint(s)}" }]
          },
          params[:status]
        ),
        {},
        { class: 'index-filter-select', data: { action: 'change->auto-submit#submitNow' } } %>
    </div>
    <% if user_signed_in? && !current_user.guest? %>
      <label class="index-filter-checkbox-label">
        <%= f.check_box :my_entries, { checked: params[:my_entries] == "1", class: 'index-filter-checkbox',
              data: { action: 'change->auto-submit#submitNow' } } %>
        Entered
      </label>
    <% end %>
    <%= link_to 'Reset', tournaments_path, class: 'btn btn-outline index-filter-reset' %>
  </div>
<% end %>

<%= render layout: "shared/index_results", locals: { frame: "tournaments", pagy: @pagy, present: @tournaments.any?, empty: "No tournaments found." } do %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Owner</th>
        <th>Status</th>
        <th>Entries</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% @tournaments.each do |tournament| %>
        <tr>
          <td><%= link_to tournament.name, tournament_show_path(tournament) %></td>
          <td class="index-table-secondary"><%= tournament.creator&.username %></td>
          <td><span class="pill pill--<%= pill_tint(tournament.status) %>"><%= tournament.status.humanize %></span></td>
          <td>
            <%= tournament.tournament_entries.size %>
            <% if tournament.max_entries %>
              <span class="index-table-secondary">/ <%= tournament.max_entries %></span>
            <% end %>
          </td>
          <td class="index-table-secondary index-table-date"><%= tournament.created_at.to_date.to_fs(:long) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
</div>
