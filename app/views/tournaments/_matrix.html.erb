<div class="match-setup-section">
  <h2>Matchup Matrix</h2>
  <p><strong>Rows:</strong> White player. <strong>Columns:</strong> Black player.</p>
  <p>Cell format: white points - black points, then draws and failed counts.</p>

  <div class="tournament-pairing-matrix-wrap">
    <table class="tournament-pairing-matrix">
      <thead>
        <tr>
          <th>White \ Black</th>
          <% entrants.each do |black_bot| %>
            <th><%= black_bot.name %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% entrants.each do |white_bot| %>
          <tr data-tournament-row="matrix-<%= white_bot.id %>">
            <th><%= white_bot.name %></th>
            <% entrants.each do |black_bot| %>
              <td
                class="tournament-pairing-matrix__cell"
                data-tournament-field="matrix-<%= white_bot.id %>-<%= black_bot.id %>"
              >
                <% if white_bot == black_bot %>
                  -
                <% else %>
                  <% summary = tournament.directional_pairing_summary(white_bot, black_bot) %>
                  <%= link_to tournament_pairing_path(tournament, white_bot, black_bot), class: 'tournament-pairing-matrix__link' do %>
                    <span class="tournament-pairing-matrix__primary">
                      <%= summary[:white_wins] %> - <%= summary[:black_wins] %> - <%= summary[:draws] %>
                    </span>
                    <span class="tournament-pairing-matrix__secondary">
                      fails <%= summary[:failed] %>
                    </span>
                  <% end %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
