<div class="setup-section">
  <h2>Matchup Matrix</h2>
  <p><strong>Rows:</strong> White player. <strong>Columns:</strong> Black player.</p>
  <p>Cell format: white points - black points, then draws and failed counts.</p>

  <% matrix = tournament_presenter.pairing_matrix %>
  <div class="tournament-pairing-matrix-wrap">
    <table class="tournament-pairing-matrix">
      <thead>
        <tr>
          <th>White \ Black</th>
          <% entrants.each do |black_entrant| %>
            <th><%= black_entrant.display_name %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% entrants.each do |white_entrant| %>
          <tr data-tournament-row="matrix-<%= white_entrant.id %>">
            <th><%= white_entrant.display_name %></th>
            <% entrants.each do |black_entrant| %>
              <td
                class="tournament-pairing-matrix__cell"
                data-tournament-field="matrix-<%= white_entrant.id %>-<%= black_entrant.id %>"
              >
                <% if white_entrant == black_entrant %>
                  -
                <% else %>
                  <% record = matrix[[white_entrant.id, black_entrant.id]] %>
                  <% pairing_path = if local_assigns[:invite_token].present?
                    invitation_tournament_pairing_path(local_assigns[:invite_token], white_entrant, black_entrant)
                  else
                    pairing_public_tournament_path(tournament, white_entrant, black_entrant)
                  end %>
                  <%= link_to pairing_path, class: 'tournament-pairing-matrix__link' do %>
                    <span class="tournament-pairing-matrix__primary">
                      <%= record.wins_for(white_entrant) %> - <%= record.wins_for(black_entrant) %> - <%= record.draws %>
                    </span>
                    <span class="tournament-pairing-matrix__secondary">
                      fails <%= record.failed %>
                    </span>
                  <% end %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
