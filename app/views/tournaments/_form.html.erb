<%= form_with url: url, scope: :tournament, method: method, local: true do |form| %>
  <div class="tournament-setup-grid">
    <div class="tournament-setup-col">

      <div class="setup-section">
        <h2>Details</h2>
        <div class="form-field">
          <label for="tournament_name">Name</label>
          <input type="text" id="tournament_name"
            name="tournament[name]"
            value="<%= @name %>">
        </div>
        <div class="form-field">
          <label for="tournament_description">Description</label>
          <textarea id="tournament_description" name="tournament[description]" rows="5"><%= @description %></textarea>
        </div>
      </div>

      <div class="setup-section">
        <h2>Format</h2>
        <div class="form-field form-field-narrow">
          <label for="tournament_games_per_pair">Games per pairing</label>
          <input type="number" id="tournament_games_per_pair"
            name="tournament[games_per_pair]"
            value="<%= @games_per_pair %>"
            min="1" max="<%= Tournaments::CreateTournament::MAX_GAMES_PER_PAIR %>" step="1">
        </div>
      </div>

      <button type="submit" class="btn btn-primary"><%= submit_label %></button>
    </div>

    <div class="tournament-setup-col">

      <div class="setup-section">
        <h2>Access</h2>
        <div class="form-field">
          <label>Visibility</label>
          <div class="ci-pills">
            <% Tournament.visibilities.keys.each do |v| %>
              <label class="ci-pill">
                <input type="radio" name="tournament[visibility]" value="<%= v %>"
                  <%= "checked" if @visibility == v || (@visibility.nil? && v == 'link_only') %>>
                <span><%= v.humanize %></span>
              </label>
            <% end %>
          </div>
        </div>
      </div>

      <div class="setup-section">
        <h2>Entries</h2>
        <div class="form-field">
          <label>Per user</label>
          <div class="ci-pills">
            <% Tournament.entries_per_users.keys.each do |e| %>
              <label class="ci-pill">
                <input type="radio" name="tournament[entries_per_user]" value="<%= e %>"
                  <%= "checked" if @entries_per_user == e || (@entries_per_user.nil? && e == 'one') %>>
                <span><%= e.humanize %></span>
              </label>
            <% end %>
          </div>
        </div>
        <div class="form-field form-field-narrow">
          <label for="tournament_max_entries">Max entries</label>
          <input type="number" id="tournament_max_entries"
            name="tournament[max_entries]"
            value="<%= @max_entries %>"
            min="2" step="1" placeholder="unlimited">
        </div>
      </div>

    </div>
  </div>

  <div data-controller="constraints-eligibility"
       data-constraints-eligibility-url-value="<%= eligibility_checks_path %>">
  <details class="constraints-section" <%= "open" if @constraints.present? %>>
    <summary class="constraints-summary">Bot Eligibility Constraints</summary>
    <div class="constraints-body">
      <p class="constraints-explainer">Constraints limit which bots may enter. Assign costs to a bot's building blocks against a total budget, restrict its structure, or ban specific condition and score types — bots that exceed the limits can't be submitted.</p>

      <div class="constraints-grid">

        <%# ── Budget ──────────────────────────────────────── %>
        <div>
          <p class="ci-heading">Budget</p>
          <div class="ci-row">
            <span class="ci-label">Total budget</span>
            <input class="ci-input ci-input--box" type="number"
              name="tournament[constraints][budget]"
              value="<%= @constraints&.dig("budget") %>"
              min="0" step="1" placeholder="N/A"
              onblur="if(this.value==='0')this.value=''">
          </div>
          <p class="ci-subheading">Costs</p>
          <% constraint_cost_labels.each do |key, label| %>
            <div class="ci-row">
              <span class="ci-label"><%= label %></span>
              <input class="ci-input ci-input--box" type="number"
                name="tournament[constraints][costs][<%= key %>]"
                value="<%= @constraints&.dig("costs", key) %>"
                min="0" step="1" placeholder="N/A"
                onblur="if(this.value==='0')this.value=''">
            </div>
          <% end %>
        </div>

        <%# ── Structure ───────────────────────────────────── %>
        <div class="ci-structure">
          <p class="ci-heading">Structure</p>
          <div class="ci-row">
            <span class="ci-label">Disallow chained conditions (AND)</span>
            <label class="ci-toggle">
              <input type="checkbox"
                name="tournament[constraints][allow_and]"
                value="false"
                <%= "checked" if @constraints&.dig("allow_and") == false %>>
              <span class="ci-toggle-track"></span>
            </label>
          </div>
          <div class="ci-row">
            <span class="ci-label">Disallow merged branches (OR)</span>
            <label class="ci-toggle">
              <input type="checkbox"
                name="tournament[constraints][allow_or]"
                value="false"
                <%= "checked" if @constraints&.dig("allow_or") == false %>>
              <span class="ci-toggle-track"></span>
            </label>
          </div>
          <div class="ci-row">
            <span class="ci-label">Max branch length</span>
            <input class="ci-input ci-input--box" type="number"
              name="tournament[constraints][max_branch_length]"
              value="<%= @constraints&.dig("max_branch_length") %>"
              min="1" step="1" placeholder="N/A">
          </div>
          <p class="ce-check-note">Counts chained conditions only — score nodes don't add to the length.</p>
          <%= render 'constraints_legend' %>
        </div>

        <%# ── Banned ──────────────────────────────────────── %>
        <div>
          <p class="ci-heading">Banned Condition Kinds</p>
          <div class="ci-pills">
            <% constraint_condition_kind_labels.each do |kind, label| %>
              <label class="ci-pill">
                <input type="checkbox"
                  name="tournament[constraints][condition_restrictions][banned_kinds][]"
                  value="<%= kind %>"
                  <%= "checked" if @constraints&.dig("condition_restrictions", "banned_kinds")&.include?(kind) %>>
                <span><%= label %></span>
              </label>
            <% end %>
          </div>
          <p class="ce-check-note">Some conditions built in the editor's Captures tab are stored as Positions, so the Captures and Positions limits here may not line up exactly with the editor's tabs.</p>
          <p class="ci-subheading">Banned Score Actions</p>
          <div class="ci-pills">
            <% %w[add subtract set return].each do |action_type| %>
              <label class="ci-pill">
                <input type="checkbox"
                  name="tournament[constraints][score_node_restrictions][banned_action_types][]"
                  value="<%= action_type %>"
                  <%= "checked" if @constraints&.dig("score_node_restrictions", "banned_action_types")&.include?(action_type) %>>
                <span><%= action_type %></span>
              </label>
            <% end %>
          </div>
          <p class="ci-subheading">Score Limitations</p>
          <div class="ci-row">
            <span class="ci-label">Max total absolute value of scores</span>
            <input class="ci-input ci-input--box" type="number"
              name="tournament[constraints][max_total_absolute_value]"
              value="<%= @constraints&.dig("max_total_absolute_value") %>"
              min="1" step="1" placeholder="N/A">
          </div>
          <p class="ce-check-note">−8 adds 8 to the total, the same as +8.</p>
        </div>

      </div>

      <div class="ce-check-bar">
        <button type="button" class="btn btn-outline ce-check-btn"
                data-constraints-eligibility-target="button"
                data-action="click->constraints-eligibility#check">Check my bots</button>
        <span class="ce-check-note">Checks against current (unsaved) settings</span>
      </div>
      <div data-constraints-eligibility-target="panel" hidden></div>
    </div>
  </details>
  </div>

<% end %>
