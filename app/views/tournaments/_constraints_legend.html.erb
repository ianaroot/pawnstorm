<div class="constraints-legend">
  <div class="constraints-legend__item">
    <svg class="constraints-legend__svg" viewBox="0 0 60 66" width="44" height="48" aria-hidden="true">
      <line x1="30" y1="22" x2="30" y2="44" stroke="#4CAF50" stroke-width="2" />
      <rect x="8" y="4" width="44" height="18" rx="9" fill="#252220" stroke="#A855F7" stroke-width="2" />
      <rect x="8" y="44" width="44" height="18" rx="9" fill="#252220" stroke="#A855F7" stroke-width="2" />
    </svg>
    <p class="constraints-legend__term">AND — chained conditions</p>
  </div>

  <div class="constraints-legend__item">
    <div>
      <p class="constraints-legend__term">OR — merged branches</p>
      <div class="constraints-legend__cases">
        <div class="constraints-legend__case">
          <svg class="constraints-legend__svg" viewBox="0 0 64 66" width="40" height="41" aria-hidden="true">
            <line x1="17" y1="20" x2="32" y2="44" stroke="#4CAF50" stroke-width="2" />
            <line x1="47" y1="20" x2="32" y2="44" stroke="#4CAF50" stroke-width="2" />
            <rect x="2" y="4" width="30" height="16" rx="8" fill="#252220" stroke="#A855F7" stroke-width="2" />
            <rect x="32" y="4" width="30" height="16" rx="8" fill="#252220" stroke="#A855F7" stroke-width="2" />
            <rect x="17" y="44" width="30" height="16" rx="8" fill="#252220" stroke="#A855F7" stroke-width="2" />
          </svg>
          <p class="constraints-legend__note">Merging two conditions: <strong>1 OR + 2 ANDs</strong> (the two joining edges).</p>
        </div>
        <div class="constraints-legend__case">
          <svg class="constraints-legend__svg" viewBox="0 0 64 74" width="40" height="46" aria-hidden="true">
            <line x1="17" y1="20" x2="32" y2="42" stroke="#4CAF50" stroke-width="2" />
            <line x1="47" y1="20" x2="32" y2="42" stroke="#4CAF50" stroke-width="2" />
            <rect x="2" y="4" width="30" height="16" rx="8" fill="#252220" stroke="#A855F7" stroke-width="2" />
            <rect x="32" y="4" width="30" height="16" rx="8" fill="#252220" stroke="#A855F7" stroke-width="2" />
            <polygon points="32,42 46,56 32,70 18,56" fill="#252220" stroke="#18b7cf" stroke-width="2" />
          </svg>
          <p class="constraints-legend__note">Merging onto a score: <strong>1 OR, no ANDs</strong>.</p>
        </div>
      </div>
    </div>
  </div>
</div>
