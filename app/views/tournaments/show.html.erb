<div class="match-show-page">
  <% if (@tournament.pending_matches_count.positive? || @tournament.running_matches_count.positive?) && !@tournament.paused? %>
    <meta http-equiv="refresh" content="2">
  <% end %>

  <div class="match-replay-layout">
    <div class="game-page">
      <div class="match-show-meta">
        <h1 class="match-show-title">Tournament <%= @tournament.id %></h1>
        <p class="match-show-meta-item"><strong>Status:</strong> <%= @tournament.overall_status.humanize %></p>
        <p class="match-show-meta-item"><strong>Entrants:</strong> <%= @tournament.entrants.map(&:name).join(', ') %></p>
        <p class="match-show-meta-item"><strong>Games Per Pair:</strong> <%= @tournament.games_per_pair %></p>
        <% if @tournament.pending_matches_count.positive? || @tournament.running_matches_count.positive? %>
          <p class="match-show-meta-item">
            <% if @tournament.paused? %>
              <%= button_to 'Resume Tournament', resume_tournament_path(@tournament), method: :post %>
            <% else %>
              <%= button_to 'Pause Tournament', pause_tournament_path(@tournament), method: :post, data: { turbo_confirm: 'Pause this tournament? The current running match may finish, but no new matches will be queued.' } %>
            <% end %>
          </p>
          <p class="match-show-meta-item">
            <%= button_to 'Abort Tournament', abort_tournament_path(@tournament), method: :post, data: { turbo_confirm: 'Abort this tournament? Pending matches will be marked failed.' } %>
          </p>
        <% end %>
      </div>

      <div class="match-setup-section">
        <h2>Progress</h2>
        <p><strong>Total Matches:</strong> <%= @tournament.total_matches_count %></p>
        <p><strong>Pending:</strong> <%= @tournament.pending_matches_count %></p>
        <p><strong>Running:</strong> <%= @tournament.running_matches_count %></p>
        <p><strong>Completed:</strong> <%= @tournament.completed_matches_count %></p>
        <p><strong>Failed:</strong> <%= @tournament.failed_matches_count %></p>
      </div>

      <div class="match-setup-section">
        <h2>Standings</h2>
        <table>
          <thead>
            <tr>
              <th>Bot</th>
              <th>Points</th>
              <th>Wins</th>
              <th>Draws</th>
              <th>Losses</th>
              <th>Completed</th>
              <th>Failed</th>
            </tr>
          </thead>
          <tbody>
            <% @standings.each do |row| %>
              <tr>
                <td><%= row[:bot].name %></td>
                <td><%= row[:points] %></td>
                <td><%= row[:wins] %></td>
                <td><%= row[:draws] %></td>
                <td><%= row[:losses] %></td>
                <td><%= row[:completed] %></td>
                <td><%= row[:failed] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="match-replay-sidebar">
      <div class="match-replay-sidebar-top">
        <h2>Pairings</h2>
        <% @pairings.each do |pairing| %>
          <div class="match-setup-section">
            <h3><%= pairing[:bot_a].name %> vs <%= pairing[:bot_b].name %></h3>
            <p>
              <strong>Record:</strong>
              <%= pairing[:bot_a].name %> <%= pairing[:record][:bot_a_points] %> -
              <%= pairing[:record][:bot_b_points] %> <%= pairing[:bot_b].name %>
              (<%= pairing[:record][:bot_a_wins] %>-<%= pairing[:record][:bot_b_wins] %>, draws: <%= pairing[:record][:draws] %>, failed: <%= pairing[:record][:failed] %>)
            </p>

            <ul>
              <% pairing[:matches].each do |match| %>
                <li>
                  <%= link_to "Match #{match.id}", match_path(match) %>
                  -
                  White: <%= match.white_player.respond_to?(:name) ? match.white_player.name : "#{match.white_player_type} #{match.white_player_id}" %>
                  /
                  Black: <%= match.black_player.respond_to?(:name) ? match.black_player.name : "#{match.black_player_type} #{match.black_player_id}" %>
                  /
                  Status: <%= match.status %>
                  <% if match.result.present? %>
                    /
                    Result: <%= match.result %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
