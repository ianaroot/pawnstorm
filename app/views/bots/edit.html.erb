<h1>Editing Bot: <%= @bot.name %></h1>

<div class="bot-editor"
     data-controller="editor bot-guide"
     data-editor-bot-id-value="<%= @bot.id %>"
     data-editor-bot-stale-value="<%= @bot.compiled_program_stale? %>">
  <div class="editor-toolbar">
    <div class="toolbar-section">
      <h3>Add Node</h3>
      <button type="button" class="btn-add-node" data-type="condition">+ Condition</button>
      <button type="button" class="btn-add-node" data-type="action">+ Action</button>
    </div>
    
    <div class="toolbar-section">
      <h3>Tool</h3>
      <button type="button" class="tool-select active" data-tool="select">Select</button>
      <button type="button" class="btn-delete-node" disabled title="Delete selected node (Delete/Backspace)">Delete</button>
      <button
        type="button"
        class="btn-guide"
        data-bot-guide-target="toggle"
        data-action="click->bot-guide#toggle"
        aria-controls="bot-guide-drawer"
        aria-expanded="false">Guide</button>
    </div>

    <div class="toolbar-section">
      <h3>View</h3>
      <button type="button" id="zoom-out" class="btn-zoom">-</button>
      <span id="zoom-level">100%</span>
      <button type="button" id="zoom-in" class="btn-zoom">+</button>
      <button type="button" id="zoom-reset" class="btn-zoom-reset">Reset</button>
    </div>

    <div class="toolbar-section">
      <h3>History</h3>
      <button type="button" class="btn-undo" disabled title="Undo (Ctrl+Z)">
        ↩ Undo <span class="undo-count">(0/50)</span>
      </button>
      <button type="button" class="btn-redo" disabled title="Redo (Ctrl+Y)">
        ↪ Redo
      </button>
    </div>

    <div class="toolbar-section">
      <%= link_to 'Back to Bots', bots_path, class: 'btn-back' %>
      <%= link_to 'Play Test Match', new_match_path, class: 'btn-test' %>
      <%= link_to 'compile and exit to match setup',
          compile_bot_path(@bot),
          data: { turbo_method: :post },
          class: "btn-test#{' hidden' unless @bot.compiled_program_stale?}",
          id: 'compile-and-exit-link' %>
    </div>
  </div>

  <div class="editor-main">
    <div class="canvas-container">
      <div id="canvas-workspace" class="canvas-workspace">
        <div id="canvas-scene" class="canvas-scene">
          <div id="nodes-canvas" class="nodes-layer" data-bot-id="<%= @bot.id %>">
            <!-- Nodes rendered by NodeRenderer -->
          </div>
          <svg id="connections-canvas" class="connections-layer">
            <!-- Connections rendered by ConnectionRenderer -->
          </svg>
        </div>
      </div>
    </div>
  </div>

  <aside id="bot-guide-drawer" class="bot-guide-drawer hidden" data-bot-guide-target="drawer">
    <div class="bot-guide-drawer__header">
      <div>
        <p class="bot-guide-drawer__eyebrow">In-Editor Guide</p>
        <h2>Build a Chess Bot</h2>
      </div>

      <button
        type="button"
        class="bot-guide-drawer__close"
        data-action="click->bot-guide#close"
        aria-label="Close guide">Close</button>
    </div>

    <p class="bot-guide-drawer__intro"><%= BotGuide.drawer_intro %></p>

    <nav class="bot-guide-drawer__index" aria-label="Guide sections">
      <ol>
        <% BotGuide.sections.each do |section| %>
          <li>
            <button
              type="button"
              class="bot-guide-drawer__index-link"
              data-action="click->bot-guide#scrollToSection"
              data-section-id="<%= section[:id] %>"><%= section[:title] %></button>
          </li>
        <% end %>
      </ol>
    </nav>

    <div class="bot-guide-drawer__content" data-bot-guide-target="content">
      <%= render 'shared/bot_guide', sections: BotGuide.sections, mode: :drawer %>
    </div>

    <div class="bot-guide-drawer__footer">
      <%= link_to 'Read Full Guide', bot_help_path, class: 'btn-guide-link' %>
    </div>
  </aside>

  <%= render "bots/nodes/editor" %>
</div>
