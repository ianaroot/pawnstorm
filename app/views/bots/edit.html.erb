<% content_for :page_content_class, 'page-content--bot-editor' %>

<div class="bot-editor-shell">
  <div class="bot-editor"
     data-controller="editor tour"
     data-editor-bot-id-value="<%= @bot.id %>"
     data-editor-bot-name-value="<%= @bot.name %>"
     data-editor-bot-description-value="<%= @bot.description.to_s %>"
     data-editor-bot-stale-value="<%= @bot.compiled_program_stale? %>"
     data-tour-set-value="editor-first-bot"
     data-tour-auto-value="<%= @auto_start_tour %>">
  <div class="bot-editor-header">
    <div class="bot-editor-header__name" id="bot-name-display" title="<%= @bot.name %>"><%= @bot.name %></div>
    <button type="button" class="bot-editor-header__rename" data-bot-rename-open>Rename</button>
  </div>

  <div class="editor-toolbar">
    <div class="toolbar-section">
      <div class="toolbar-section__heading">
        <h3>Add Node</h3>
        <button
          type="button"
          class="btn-guide"
          data-action="click->tour#start">Take the tour</button>
        <button type="button" class="btn-open-templates">Templates</button>
      </div>
      <button type="button" class="btn-add-node" data-type="condition">+ Condition</button>
      <button type="button" class="btn-add-node" data-type="score">+ Score</button>
      <button type="button" class="btn-add-node" data-type="organizer">+ Organizer</button>
    </div>

    <div class="toolbar-section toolbar-section--tool">
      <div class="toolbar-section__heading">
        <h3>Tool</h3>
        <div class="toolbar-popover-anchor" data-controller="tips-popover">
          <button type="button"
                  class="btn-tips-toggle"
                  data-tips-popover-target="button"
                  data-action="click->tips-popover#toggle"
                  aria-haspopup="dialog"
                  aria-expanded="false"
                  aria-label="Editor tips and Bot Guide">?</button>
          <%= render 'bots/tips_popover' %>
        </div>
      </div>
      <button type="button" class="btn-delete-node" disabled title="Delete selected node (Delete/Backspace)">Delete</button>
    </div>

    <div class="toolbar-section">
      <div class="toolbar-section__heading">
        <h3>View</h3>
        <button type="button" class="btn-toggle-preview-mode" aria-pressed="true"
          title="Show condition previews as plain-language sentences or terse chunks (reopen a panel to apply)">Sentences: on</button>
      </div>
      <button type="button" id="zoom-out" class="btn-zoom">-</button>
      <span id="zoom-level">100%</span>
      <button type="button" id="zoom-in" class="btn-zoom">+</button>
    </div>

    <div class="toolbar-section">
      <h3>History</h3>
      <button type="button" class="btn-undo" disabled title="Undo (Ctrl+Z)">
        ↩ Undo <span class="undo-count">(0/50)</span>
      </button>
      <button type="button" class="btn-redo" disabled title="Redo (Ctrl+Y)">
        ↪ Redo
      </button>
    </div>

    <div class="toolbar-section toolbar-right-group">
      <div class="toolbar-right-group__top">
        <%= link_to 'compile bot',
            compile_bot_path(@bot),
            data: { turbo_method: :post },
            class: "btn-test#{' hidden' unless @bot.compiled_program_stale?}",
            id: 'compile-and-exit-link' %>
        <span id="compile-status" class="compile-status hidden"></span>
        <%= button_to 'Clone Bot',
            clone_bot_path(@bot),
            method: :post,
            class: 'btn-clone',
            data: { turbo_confirm: "Clone \"#{@bot.name}\"? A compiled copy will be created." } %>
      </div>
      <div class="toolbar-eligibility"
           data-controller="bot-eligibility"
           data-bot-eligibility-bot-id-value="<%= @bot.id %>"
           data-bot-eligibility-stale-value="<%= @bot.compiled_program_stale? %>">
        <button type="button" class="toolbar-eligibility__toggle" data-action="click->bot-eligibility#toggle">Check tournament eligibility</button>
        <div class="toolbar-eligibility__panel" data-bot-eligibility-target="panel" hidden>
          <select data-bot-eligibility-target="select"
                  data-action="change->bot-eligibility#tournamentChanged">
            <% if @open_tournaments.any? %>
              <option value="">— tournament —</option>
              <% @open_tournaments.each do |t| %>
                <option value="<%= t.id %>"><%= t.name %></option>
              <% end %>
            <% else %>
              <option value="" disabled>No open tournaments</option>
            <% end %>
          </select>
          <small class="toolbar-eligibility__note">Only tournaments with eligibility constraints are listed.</small>
          <input type="text" placeholder="invite token"
                 data-bot-eligibility-target="inviteInput"
                 data-action="keydown.enter->bot-eligibility#lookupInviteTournament">
          <span class="toolbar-eligibility__status" data-bot-eligibility-target="status"></span>
        </div>
      </div>
    </div>
  </div>

  <div class="editor-main">
    <div class="canvas-container">
      <div id="canvas-workspace" class="canvas-workspace">
        <div id="canvas-scene" class="canvas-scene">
          <div id="nodes-canvas" class="nodes-layer" data-bot-id="<%= @bot.id %>">
            <!-- Nodes rendered by NodeRenderer -->
          </div>
          <svg id="connections-canvas" class="connections-layer">
            <!-- Connections rendered by ConnectionRenderer -->
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div id="template-picker-modal" class="template-picker-modal hidden" aria-hidden="true">
    <div class="template-picker-modal__backdrop" data-template-picker-close></div>

    <div class="template-picker-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="template-picker-title">
      <div class="template-picker-modal__header">
        <div>
          <p class="template-picker-modal__eyebrow">Template Chunks</p>
          <h2 id="template-picker-title">Insert a Template</h2>
        </div>

        <button type="button" class="template-picker-modal__close" data-template-picker-close>Close</button>
      </div>

      <div class="template-picker-modal__body">
        <aside class="template-picker-modal__sidebar">
          <nav class="template-picker__categories" aria-label="Template categories" data-template-picker-categories></nav>
          <div class="template-picker__list" data-template-picker-list></div>
        </aside>

        <section class="template-picker-modal__detail">
          <p class="template-picker-modal__category" data-template-picker-category></p>
          <h3 class="template-picker-modal__name" data-template-picker-title></h3>
          <p class="template-picker-modal__description" data-template-picker-description></p>
          <div class="template-picker-modal__preview" data-template-picker-preview></div>

          <div class="template-picker-modal__actions">
            <button type="button" class="btn btn-primary template-picker-modal__insert" data-template-picker-insert>Insert Template</button>
          </div>
        </section>
      </div>
    </div>
  </div>

  <div id="bot-rename-modal" class="bot-rename-modal hidden" aria-hidden="true">
    <div class="bot-rename-modal__backdrop" aria-hidden="true"></div>
    <div class="bot-rename-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="bot-rename-title">
      <div class="bot-rename-modal__header">
        <h2 id="bot-rename-title">Rename Bot</h2>
      </div>

      <div class="bot-rename-modal__body">
        <div class="bot-rename-modal__field">
          <label for="bot-rename-name">Name</label>
          <input id="bot-rename-name" type="text" maxlength="80" value="<%= h(@bot.name) %>">
        </div>

        <div class="bot-rename-modal__field">
          <label for="bot-rename-description">Description</label>
          <textarea id="bot-rename-description" rows="5"><%= h(@bot.description.to_s) %></textarea>
        </div>

        <p class="bot-rename-modal__error hidden" data-bot-rename-error></p>
      </div>

      <div class="bot-rename-modal__actions">
        <button type="button" class="bot-rename-modal__cancel" data-bot-rename-cancel>Cancel</button>
        <button type="button" class="bot-rename-modal__save" data-bot-rename-save>Save</button>
      </div>
    </div>
  </div>

  <%= render "bots/nodes/editor" %>
  </div>
</div>
