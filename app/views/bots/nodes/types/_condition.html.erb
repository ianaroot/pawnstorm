<%
  data = node.data.is_a?(Hash) ? node.data : (JSON.parse(node.data) rescue {})
  chunks = Node.condition_preview_chunks(data)
%>

<div class="node-preview condition-preview">
  <% chunks.each do |chunk| %>
    <% if chunk.is_a?(Hash) %>
      <% role = chunk[:role] || chunk['role'] %>
      <% if role == 'spacer' %>
        <div class="condition-preview__chunk condition-preview__chunk--spacer"></div>
      <% else %>
        <div
          class="condition-preview__chunk"
          data-condition-preview-role="<%= role %>"
          <% if (value = chunk[:subject] || chunk['subject']).present? %>data-condition-preview-subject="<%= value %>"<% end %>
          <% if (value = chunk[:filter] || chunk['filter']).present? %>data-condition-preview-filter="<%= value %>"<% end %>
          <% if (value = chunk[:filter_mode] || chunk['filter_mode']).present? %>data-condition-preview-filter-mode="<%= value %>"<% end %>
          <% if (value = chunk[:comparison_metric] || chunk['comparison_metric']).present? %>data-condition-preview-comparison-metric="<%= value %>"<% end %>
          <% if (value = chunk[:comparator] || chunk['comparator']).present? %>data-condition-preview-comparator="<%= value %>"<% end %>
          <% if (value = chunk[:comparison_value] || chunk['comparison_value']).present? %>data-condition-preview-comparison-value="<%= value %>"<% end %>
          <% if chunk.key?(:comparison_open) || chunk.key?('comparison_open') %>data-condition-preview-comparison-open="<%= (chunk[:comparison_open] || chunk['comparison_open']) ? 'true' : 'false' %>"<% end %>
          <% if (value = chunk[:operator] || chunk['operator']).present? %>data-condition-preview-operator="<%= value %>"<% end %>
        ><%= chunk[:text] || chunk['text'] %></div>
      <% end %>
    <% elsif chunk == "" %>
      <div class="condition-preview__chunk condition-preview__chunk--spacer"></div>
    <% else %>
      <div class="condition-preview__chunk"><%= chunk %></div>
    <% end %>
  <% end %>
</div>
