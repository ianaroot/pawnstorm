<%
data = node.data.is_a?(Hash) ? node.data : (JSON.parse(node.data) rescue {})

valid_subjects = %w[moved_piece allies opponents captured_piece]
valid_subject_specifiers = %w[any king queen rook bishop knight pawn]
valid_relation_specifiers = %w[any king queen rook bishop knight pawn moved_piece]
valid_relations = %w[piece_count adjacent_count attacker_count defender_count shielder_count shielded_count coverer_count covered_count mobility]
valid_comparisons = %w[any none count greater_than less_than]
valid_comparison_values = %w[moved_piece_value captured_piece_value prior_board_state]

subject_labels = {
  'moved_piece' => 'Moved piece',
  'allies' => 'Allied pieces',
  'opponents' => 'Opponent pieces',
  'captured_piece' => 'Captured piece'
}

specifier_labels = {
  'any' => 'any piece',
  'king' => 'king',
  'queen' => 'queen',
  'rook' => 'rook',
  'bishop' => 'bishop',
  'knight' => 'knight',
  'pawn' => 'pawn',
  'moved_piece' => 'moved piece'
}

relation_labels = {
  'piece_count' => 'piece count',
  'adjacent_count' => 'adjacent count',
  'attacker_count' => 'attacker count',
  'defender_count' => 'defender count',
  'shielder_count' => 'shielder count',
  'shielded_count' => 'shielded count',
  'coverer_count' => 'coverer count',
  'covered_count' => 'covered count',
  'mobility' => 'mobility'
}

comparison_labels = {
  'any' => 'any',
  'none' => 'none',
  'count' => 'count',
  'greater_than' => 'greater than',
  'less_than' => 'less than'
}

comparison_value_labels = {
  'moved_piece_value' => 'value of moved piece',
  'captured_piece_value' => 'value of captured piece',
  'prior_board_state' => 'prior board state'
}

matches_new_grammar =
  data.is_a?(Hash) &&
  valid_subjects.include?(data['subject']) &&
  valid_subject_specifiers.include?(data['subjectSpecifier']) &&
  valid_relations.include?(data['relation']) &&
  valid_relation_specifiers.include?(data['relationSpecifier']) &&
  valid_comparisons.include?(data['comparison']) &&
  (
    (%w[any none].include?(data['comparison']) && data.key?('comparisonValue') && data['comparisonValue'].nil?) ||
    data['comparisonValue'].is_a?(Numeric) ||
    valid_comparison_values.include?(data['comparisonValue'])
  )

if matches_new_grammar
  subject = subject_labels[data['subject']]
  specifier = specifier_labels[data['subjectSpecifier']]
  relation = relation_labels[data['relation']]
  relation_specifier = specifier_labels[data['relationSpecifier']]
  comparison = comparison_labels[data['comparison']]
  comparison_value = comparison_value_labels[data['comparisonValue']] || data['comparisonValue']

  summary = "#{subject}: #{specifier} #{relation}"

  if data['relationSpecifier'] != 'any'
    summary += " #{relation_specifier}"
  end

  if comparison == 'any'
    summary += ' (any)'
  elsif comparison == 'none'
    summary += ' (none)'
  elsif comparison_value.present?
    summary += " (#{comparison} #{comparison_value})"
  end
end
%>
<% if matches_new_grammar %>
  <div class="node-preview"><%= summary %></div>
<% else %>
  <%# Legacy fallback: display raw condition data when it does not match the new grammar. %>
  <div class="node-preview legacy-preview"><%= JSON.pretty_generate(data) %></div>
<% end %>
