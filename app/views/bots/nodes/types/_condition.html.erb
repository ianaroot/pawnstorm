<%
data = node.data.is_a?(Hash) ? node.data : (JSON.parse(node.data) rescue {})

subject_labels = {
  'moved_piece' => 'Moved piece',
  'allies' => 'Allied pieces',
  'opponents' => 'Opponent pieces',
  'captured_piece' => 'Captured piece'
}

specifier_labels = {
  'any' => 'any piece',
  'king' => 'king',
  'queen' => 'queen',
  'rook' => 'rook',
  'bishop' => 'bishop',
  'knight' => 'knight',
  'pawn' => 'pawn'
}

relation_labels = {
  'attacked_after_move' => 'attacker count',
  'defended_after_move' => 'defender count',
  'lost_defender' => 'defender count',
  'lost_shield' => 'shield count',
  'newly_attacked' => 'attacker count',
  'unblocked' => 'mobility',
  'piece_count' => 'piece count',
  'attacker_count' => 'attacker count',
  'defender_count' => 'defender count',
  'shield_count' => 'shield count',
  'mobility' => 'mobility'
}

comparison_labels = {
  'any' => 'any',
  'none' => 'none',
  'count' => 'count',
  'greater_than' => 'greater than',
  'less_than' => 'less than'
}

comparison_value_labels = {
  'moved_piece_value' => 'value of moved piece',
  'captured_piece_value' => 'value of captured piece',
  'prior_board_state' => 'prior board state'
}

subject = subject_labels[data['subject']] || 'Moved piece'
specifier = specifier_labels[data['specifier']] || 'any piece'
relation = relation_labels[data['relation']] || 'attacker count'
comparison = comparison_labels[data['comparison']] || 'any'
comparison_value = comparison_value_labels[data['comparisonValue']] || data['comparisonValue']

summary = "#{subject}: #{specifier} #{relation}"

if comparison == 'any'
  summary += ' (any)'
elsif comparison == 'none'
  summary += ' (none)'
elsif comparison_value.present?
  summary += " (#{comparison} #{comparison_value})"
end
%>
<div class="node-preview"><%= summary %></div>
