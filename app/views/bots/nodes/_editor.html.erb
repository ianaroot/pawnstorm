<div id="node-editor-panel" class="node-editor-panel hidden">
  <h3>Edit Node</h3>
  <div class="panel-content">
    <div class="form-group">
      <label>Type</label>
      <span id="edit-node-type"></span>
    </div>
    
    <div id="condition-editor" class="node-editor-section hidden">
      <h4>Condition</h4>

      <div id="condition-subject-group" class="editor-part">
        <label>1. Subject</label>
        <select id="cond-subject">
          <% Node.condition_subject_options.each do |label, value| %>
            <option value="<%= value %>"><%= label %></option>
          <% end %>
        </select>
      </div>

      <div id="condition-specifier-group" class="editor-part hidden">
        <label>2. Subject specifier</label>
        <select id="cond-subject-specifier">
          <% Node.condition_subject_specifier_options.each do |label, value| %>
            <option value="<%= value %>"><%= label %></option>
          <% end %>
        </select>
      </div>

      <div id="condition-relation-group" class="editor-part hidden">
        <label>3. Relation</label>
        <select id="cond-relation">
          <% Node.condition_relation_options.each do |label, value, valid_subjects| %>
            <option value="<%= value %>" data-valid-subjects="<%= valid_subjects.join(',') %>"><%= label %></option>
          <% end %>
        </select>
      </div>

      <div id="condition-relation-specifier-group" class="editor-part hidden">
        <label>4. Relation specifier</label>
        <select id="cond-relation-specifier">
          <% Node.condition_relation_specifier_options.each do |label, value, valid_subjects, valid_relations| %>
            <option
              value="<%= value %>"
              data-valid-subjects="<%= valid_subjects.join(',') %>"
              data-valid-relations="<%= valid_relations.join(',') %>"
            ><%= label %></option>
          <% end %>
        </select>
      </div>

      <div id="condition-comparison-group" class="editor-part hidden">
        <label>5. Comparison</label>
        <select id="cond-comparison">
          <% Node.condition_comparison_options.each do |label, value| %>
            <option value="<%= value %>"><%= label %></option>
          <% end %>
        </select>
      </div>

      <div id="condition-comparison-value-group" class="editor-part hidden">
        <label>6. Comparison value</label>
        <select id="cond-comparison-value-source">
          <option value="exact_number">Number</option>
          <% Node.condition_comparison_value_options.each do |label, value, valid_subjects| %>
            <option value="<%= value %>" data-valid-subjects="<%= valid_subjects.join(',') %>"><%= label %></option>
          <% end %>
        </select>
        <input id="cond-comparison-value-number" type="number" min="0" step="1" value="1">
      </div>
    </div>
    
    <div id="action-editor" class="node-editor-section hidden">
      <h4>Action</h4>
      <div class="editor-part">
        <label>1. Action</label>
        <select id="action-type">
          <option value="add">Add</option>
          <option value="subtract">Subtract</option>
          <option value="set">Set</option>
          <option value="return">Return</option>
        </select>
      </div>

      <div class="editor-part">
        <label>2. Value</label>
        <input id="action-value" type="number" step="1" value="1">
      </div>
    </div>
  </div>
  <div class="panel-actions">
    <button id="save-node" class="btn-save">Save</button>
    <button id="cancel-edit" class="btn-cancel">Cancel</button>
  </div>
</div>
